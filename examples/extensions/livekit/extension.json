{
  "id": "livekit",
  "name": "LiveKit",
  "version": "1.0.0",
  "description": "Create and manage LiveKit video/audio rooms with local dev or cloud servers. Host and participant controls for mute, camera, and agent connections.",
  "author": "contex",
  "tier": "power",
  "ui": { "mode": "native" },
  "main": "main.js",
  "permissions": ["network", "os:read"],

  "contributes": {
    "tiles": [
      {
        "type": "livekit-rooms",
        "label": "LiveKit Rooms",
        "icon": "",
        "entry": "tiles/rooms/index.html",
        "defaultSize": { "w": 480, "h": 560 },
        "minSize": { "w": 360, "h": 400 }
      },
      {
        "type": "livekit-room",
        "label": "LiveKit Room",
        "icon": "",
        "entry": "tiles/room/index.html",
        "defaultSize": { "w": 720, "h": 640 },
        "minSize": { "w": 520, "h": 440 }
      }
    ],

    "contextMenu": [
      {
        "label": "New LiveKit Rooms",
        "action": "createTile",
        "tileType": "ext:livekit-rooms"
      },
      {
        "label": "New LiveKit Room",
        "action": "createTile",
        "tileType": "ext:livekit-room"
      }
    ],

    "settings": [
      { "key": "mode", "label": "Server Mode", "type": "string", "default": "local" },
      { "key": "localPort", "label": "Local Dev Server Port", "type": "number", "default": 7880 },
      { "key": "serverUrl", "label": "LiveKit Server URL", "type": "string", "default": "" },
      { "key": "apiKey", "label": "API Key", "type": "string", "default": "" },
      { "key": "apiSecret", "label": "API Secret", "type": "string", "default": "" }
    ],

    "context": {
      "produces": ["ctx:livekit:rooms", "ctx:livekit:active-room", "ctx:livekit:participants"],
      "consumes": []
    },

    "actions": [
      { "name": "createRoom", "description": "Create a new room. Params: { name: string, maxParticipants?: number }" },
      { "name": "deleteRoom", "description": "Delete a room. Params: { name: string }" },
      { "name": "listRooms", "description": "List all active rooms." },
      { "name": "joinRoom", "description": "Join a room. Params: { room: string, identity: string, role?: string }" },
      { "name": "listParticipants", "description": "List participants. Params: { room: string }" },
      { "name": "muteParticipant", "description": "Mute a participant. Params: { room: string, identity: string, trackType: 'audio'|'video' }" },
      { "name": "unmuteParticipant", "description": "Unmute a participant. Params: { room: string, identity: string, trackType: 'audio'|'video' }" },
      { "name": "removeParticipant", "description": "Remove participant from room. Params: { room: string, identity: string }" },
      { "name": "getServerStatus", "description": "Get server connection status." }
    ],

    "mcpTools": [
      {
        "name": "livekit_list_rooms",
        "description": "List all active LiveKit rooms",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "livekit_create_room",
        "description": "Create a new LiveKit room",
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "Room name" },
            "maxParticipants": { "type": "number", "description": "Max participants (0 = unlimited)" }
          },
          "required": ["name"]
        }
      },
      {
        "name": "livekit_join_room",
        "description": "Generate a join token for a room",
        "inputSchema": {
          "type": "object",
          "properties": {
            "room": { "type": "string" },
            "identity": { "type": "string" },
            "role": { "type": "string", "enum": ["host", "participant", "agent"] }
          },
          "required": ["room", "identity"]
        }
      },
      {
        "name": "livekit_list_participants",
        "description": "List participants in a room",
        "inputSchema": {
          "type": "object",
          "properties": {
            "room": { "type": "string" }
          },
          "required": ["room"]
        }
      },
      {
        "name": "livekit_mute_participant",
        "description": "Mute or unmute a participant's audio or video",
        "inputSchema": {
          "type": "object",
          "properties": {
            "room": { "type": "string" },
            "identity": { "type": "string" },
            "trackType": { "type": "string", "enum": ["audio", "video"] },
            "muted": { "type": "boolean" }
          },
          "required": ["room", "identity", "trackType", "muted"]
        }
      }
    ]
  }
}
